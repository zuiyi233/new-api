# Root local development defaults for scheme-2:
# - frontend local dev server
# - backend local Go process
# - PostgreSQL / Redis stay in Docker

PORT=36173
SQL_DSN=postgresql://root:123456@127.0.0.1:35432/new-api?sslmode=disable
REDIS_CONN_STRING=redis://127.0.0.1:36379/0
TZ=Asia/Shanghai
GIN_MODE=debug
ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true

# Note:
# 1. Copy this file to .env.dev.local if you need custom overrides.
# 2. The backend launch script reads .env.dev.local first, then falls back to these defaults.
